# ===========================================
# 微信云托管环境变量配置
# ===========================================
# 在微信云托管控制台 -> 服务设置 -> 环境变量 中配置

# ================================
# 必需配置 - 微信小程序
# ================================
WX_APP_ID=wxd244b605ba704aab
WX_APP_SECRET=ca31d883d8f0587be93e9a10a8b8b85d

# ================================
# 必需配置 - JWT 认证
# ================================
JWT_SECRET=zhangyu-broker-jwt-secret-2024-production
JWT_EXPIRES_IN=30d

# ================================
# 必需配置 - 腾讯云 COS 存储
# ================================
# 获取方式：https://console.cloud.tencent.com/cam/capi
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=xgpkRt89wVt40gHoJeAczLcgX9WhiU0G
COS_BUCKET_NAME=7072-prod-9gchot580b331407-1416950024
COS_REGION=ap-shanghai

# ================================
# 必需配置 - Supabase 数据库
# ================================
# 方式一：使用 Coze 平台的 Supabase（推荐）
# 在 Coze 平台创建项目时会自动分配 Supabase 实例
# 从 Coze 控制台获取以下配置：
COZE_SUPABASE_URL=your-supabase-url
COZE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 方式二：使用自建 Supabase
# 1. 访问 https://supabase.com 创建项目
# 2. 在项目设置 -> API 中获取 URL 和 anon key
# 3. 执行 server/drizzle 迁移脚本创建数据表

# ================================
# 可选配置 - Coze 内置存储
# ================================
# 如果需要在开发环境使用 Coze 内置存储，配置以下变量
# COZE_BUCKET_ENDPOINT_URL=
# COZE_BUCKET_NAME=

# ================================
# 系统自动注入（微信云托管）
# ================================
# 以下环境变量由微信云托管自动注入，无需手动配置：
# - KUBERNETES_SERVICE_HOST: 用于识别运行环境
# - WX_OPENID: 用户微信 OpenID（调用时自动注入）
# - WX_APPID: 小程序 AppID
