# 微信云托管部署配置 - 章鱼经纪人
# 适用于构建上下文为 server 目录的情况
# 在云托管控制台配置：
#   Dockerfile路径: Dockerfile (或 server/Dockerfile)
#   构建上下文: server

FROM node:20-alpine

# 设置工作目录
WORKDIR /app

# 安装系统依赖和 pnpm
RUN apk add --no-cache curl bash && \
    npm install -g pnpm

# 设置环境变量
ENV NODE_ENV=production
ENV PORT=3000

# 复制 package 文件（只需要 server 目录的）
COPY package.json ./

# 安装生产依赖
RUN pnpm install --prod --no-optional

# 复制已构建的 dist 目录
# ⚠️ 使用此 Dockerfile 需要先在本地构建好 dist 目录
COPY dist ./dist

# 暴露端口
EXPOSE 3000

# 启动服务
CMD ["node", "dist/main.js"]
